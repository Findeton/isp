<mo fence=3D"false" rspace=3D"0.167em" stretchy=3D"false">|</mo><mi>j</mi><=
mo>,</mo><msub><mi>t</mi><mn>0</mn></msub></mrow></mrow><mo>)</mo></mrow><a=
nnotation encoding=3D"application/x-tex">p\mathopen{}\mathclose{{\left(i,t|=
j,t_{0}}}\right)</annotation><annotation encoding=3D"application/x-llamapun=
">italic_p start_OPEN end_OPEN start_CLOSE ( italic_i , italic_t | italic_j=
 , italic_t start_POSTSUBSCRIPT 0 end_POSTSUBSCRIPT end_CLOSE )</annotation=
