row><mi>=CF=81</mi><mo stretchy=3D"false">=E2=86=A6</mo><mrow><mi></mi><mro=
w><mo>(</mo><mn>1</mn><mo>=E2=88=92</mo><mi>p</mi></mrow></mrow><mo>)</mo><=
mi>=CF=81</mi><mo>+</mo><mi>p</mi><mi>=CF=83</mi><msub><mi></mi><mi>x</mi><=
/msub><mi>=CF=81</mi><mi>=CF=83</mi><msub><mi></mi><mi>x</mi></msub></mrow>=
<annotation encoding=3D"application/x-tex">\rho\mapsto\mathopen{}\mathclose=
{{\left(1-p}}\right)\rho+p\sigma_{x}\rho\sigma_{x}</annotation><annotation =
encoding=3D"application/x-llamapun">italic_=CF=81 =E2=86=A6 start_OPEN end_=
