ics></math>,
where <math alttext=3D"p" class=3D"ltx_Math" display=3D"inline" id=3D"footn=
ote3.m4"><semantics><mi>p</mi><annotation encoding=3D"application/x-tex">p<=
/annotation><annotation encoding=3D"application/x-llamapun">italic_p</annot=
ation></semantics></math> is a probability not equal to <math alttext=3D"1/=
2" class=3D"ltx_Math" display=3D"inline" id=3D"footnote3.m5"><semantics><mr=
ow><mn>1</mn><mo>/</mo><mn>2</mn></mrow><annotation encoding=3D"application=
/x-tex">1/2</annotation><annotation encoding=3D"application/x-llamapun">1 /=
 2</annotation></semantics></math> and where <math alttext=3D"\sigma_{x}" c=
lass=3D"ltx_Math" display=3D"inline" id=3D"footnote3.m6"><semantics><msub><=
