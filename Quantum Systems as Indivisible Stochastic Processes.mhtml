1"><semantics><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=9E</mi><anno=
tation encoding=3D"application/x-tex">\mathcal{C}</annotation><annotation e=
ncoding=3D"application/x-llamapun">caligraphic_C</annotation></semantics></=
math>
