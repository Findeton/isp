><mo>)</mo></mrow><mi>U</mi><mrow><mi></mi><mrow><mo>(</mo><msup><mi>t</mi>=
<mo>=E2=80=B2</mo></msup><mo stretchy=3D"false">=E2=86=90</mo><mn>0</mn></m=
