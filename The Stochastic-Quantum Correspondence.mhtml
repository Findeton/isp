\right)</annotation><annotation encoding=3D"application/x-llamapun">roman_=
=CE=93 start_OPEN end_OPEN start_CLOSE ( italic_t =E2=86=90 0 end_CLOSE )</=
annotation></semantics></math>
on an underlying configuration space <math alttext=3D"\mathcal{C}" class=3D=
"ltx_Math" display=3D"inline" id=3D"S3.SS4.p10.m3"><semantics><mi class=3D"=
ltx_font_mathcaligraphic">=F0=9D=92=9E</mi><annotation encoding=3D"applicat=
ion/x-tex">\mathcal{C}</annotation><annotation encoding=3D"application/x-ll=
amapun">caligraphic_C</annotation></semantics></math>, as noted, for
