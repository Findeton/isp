se">|</mo><msub><mi>j</mi><mn>1</mn></msub><mo>,</mo><msub><mi>t</mi><mn>1<=
/mn></msub><mo>;</mo><msub><mi>j</mi><mn>2</mn></msub><mo>,</mo><msub><mi>t=
</mi><mn>2</mn></msub><mo>;</mo><mi mathvariant=3D"normal">=E2=80=A6</mi></=
