tx_Math" display=3D"inline" id=3D"S5.SS5.p1.2.m2" intent=3D":literal"><sema=
ntics><msup><mi mathvariant=3D"normal">=CE=A3</mi><mi>n</mi></msup><annotat=
ion encoding=3D"application/x-tex">\Sigma^{n}</annotation></semantics></mat=
h> at every
integer time step <math alttext=3D"n\,\delta t" class=3D"ltx_Math" display=
=3D"inline" id=3D"S5.SS5.p1.3.m3" intent=3D":literal"><semantics><mrow><mi>=
n</mi><mo lspace=3D"0.170em" rspace=3D"0em">=E2=80=8B</mo><mi>=CE=B4</mi><m=
o lspace=3D"0em" rspace=3D"0em">=E2=80=8B</mo><mi>t</mi></mrow><annotation =
