tag">20</span></a>)
will break down. In that case, the time-dependent dynamical maps <math altt=
ext=3D"f_{t}" class=3D"ltx_Math" display=3D"inline" id=3D"footnote4.m6" int=
ent=3D":literal"><semantics><msub><mi>f</mi><mi>t</mi></msub><annotation en=
coding=3D"application/x-tex">f_{t}</annotation></semantics></math>
will not necessarily have inverses.</span></span></span></p><button class=
=3D"sr-only button" style=3D"display: none;">Report issue for preceding ele=
ment</button>
</div>
</li>
</ul>
</div>
</section>
<section class=3D"ltx_subsection" id=3D"S2.SS3">
<h3 class=3D"ltx_title ltx_title_subsection">
<span class=3D"ltx_tag ltx_tag_subsection">2.3 </span>Markovian-Homogeneous=
 Dynamical Systems</h3><button class=3D"sr-only button" style=3D"display: n=
one;">Report issue for preceding element</button>
<div class=3D"ltx_para" id=3D"S2.SS3.p1">
<p class=3D"ltx_p" id=3D"S2.SS3.p1.7">A Markovian dynamical system will be =
called <em class=3D"ltx_emph ltx_font_italic" id=3D"S2.SS3.p1.7.1">Markovia=
n-homogeneous</em>
(or <em class=3D"ltx_emph ltx_font_italic" id=3D"S2.SS3.p1.7.2">time-homoge=
neous</em>) if it has the special property</p><button class=3D"sr-only butt=
on" style=3D"display: none;">Report issue for preceding element</button>
<table class=3D"ltx_equation ltx_eqn_table" id=3D"S2.E21">
<tbody><tr class=3D"ltx_equation ltx_eqn_row ltx_align_baseline">
<td class=3D"ltx_eqn_cell ltx_eqn_center_padleft"></td>
<td class=3D"ltx_eqn_cell ltx_align_center"><math alttext=3D"g_{t\star t^{\=
prime}\leftarrow t^{\prime}}=3Dg_{t\leftarrow 0}\quad\mathopen{}\mathclose{=
{\left[\textrm{for all }t,t^{\prime}\in\mathcal{T}}}\right]." class=3D"ltx_=
math_unparsed" display=3D"block" id=3D"S2.E21.m1" intent=3D":literal"><sema=
ntics><mrow><msub><mi>g</mi><mrow><mrow><mi>t</mi><mo lspace=3D"0.222em" rs=
pace=3D"0.222em">=E2=8B=86</mo><msup><mi>t</mi><mo>=E2=80=B2</mo></msup></m=
row><mo stretchy=3D"false">=E2=86=90</mo><msup><mi>t</mi><mo>=E2=80=B2</mo>=
</msup></mrow></msub><mo>=3D</mo><msub><mi>g</mi><mrow><mi>t</mi><mo stretc=
hy=3D"false">=E2=86=90</mo><mn>0</mn></mrow></msub><mspace style=3D"width:1=
em;" width=3D"1em"></mspace><mrow><mi></mi><mrow><mo>[</mo><mtext>for all&n=
bsp;</mtext><mi>t</mi><mo>,</mo><msup><mi>t</mi><mo>=E2=80=B2</mo></msup><m=
o>=E2=88=88</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=AF</mi></m=
row></mrow><mo>]</mo><mo lspace=3D"0em">.</mo></mrow><annotation encoding=
=3D"application/x-tex">g_{t\star t^{\prime}\leftarrow t^{\prime}}=3Dg_{t\le=
ftarrow 0}\quad\mathopen{}\mathclose{{\left[\textrm{for all }t,t^{\prime}\i=
n\mathcal{T}}}\right].</annotation></semantics></math></td>
<td class=3D"ltx_eqn_cell ltx_eqn_center_padright"></td>
<td class=3D"ltx_eqn_cell ltx_eqn_eqno ltx_align_middle ltx_align_right" ro=
wspan=3D"1"><span class=3D"ltx_tag ltx_tag_equation ltx_align_right">(21)</=
span></td>
</tr></tbody>
</table>
<p class=3D"ltx_p" id=3D"S2.SS3.p1.1">Equivalently, using <math alttext=3D"=
f_{t}\equiv g_{t\leftarrow 0}" class=3D"ltx_Math" display=3D"inline" id=3D"=
S2.SS3.p1.1.m1" intent=3D":literal"><semantics><mrow><msub><mi>f</mi><mi>t<=
/mi></msub><mo>=E2=89=A1</mo><msub><mi>g</mi><mrow><mi>t</mi><mo stretchy=
=3D"false">=E2=86=90</mo><mn>0</mn></mrow></msub></mrow><annotation encodin=
g=3D"application/x-tex">f_{t}\equiv g_{t\leftarrow 0}</annotation></semanti=
cs></math> from (<a class=3D"ltx_ref" href=3D"https://arxiv.org/html/2309.0=
3085v2#S2.E18" title=3D"In 4th item =E2=80=A3 2.2 Markovian Dynamical Syste=
ms =E2=80=A3 2 Deterministic Systems =E2=80=A3 The Stochastic-Quantum Theor=
em"><span class=3D"ltx_text ltx_ref_tag">18</span></a>),
one can write this special property as</p><button class=3D"sr-only button" =
style=3D"display: none;">Report issue for preceding element</button>
<table class=3D"ltx_equation ltx_eqn_table" id=3D"S2.E22">
<tbody><tr class=3D"ltx_equation ltx_eqn_row ltx_align_baseline">
<td class=3D"ltx_eqn_cell ltx_eqn_center_padleft"></td>
<td class=3D"ltx_eqn_cell ltx_align_center"><math alttext=3D"g_{t\star t^{\=
prime}\leftarrow t^{\prime}}=3Df_{t}\quad\mathopen{}\mathclose{{\left[\text=
rm{for all }t,t^{\prime}\in\mathcal{T}}}\right]." class=3D"ltx_math_unparse=
d" display=3D"block" id=3D"S2.E22.m1" intent=3D":literal"><semantics><mrow>=
<msub><mi>g</mi><mrow><mrow><mi>t</mi><mo lspace=3D"0.222em" rspace=3D"0.22=
2em">=E2=8B=86</mo><msup><mi>t</mi><mo>=E2=80=B2</mo></msup></mrow><mo stre=
tchy=3D"false">=E2=86=90</mo><msup><mi>t</mi><mo>=E2=80=B2</mo></msup></mro=
w></msub><mo>=3D</mo><msub><mi>f</mi><mi>t</mi></msub><mspace style=3D"widt=
h:1em;" width=3D"1em"></mspace><mrow><mi></mi><mrow><mo>[</mo><mtext>for al=
l&nbsp;</mtext><mi>t</mi><mo>,</mo><msup><mi>t</mi><mo>=E2=80=B2</mo></msup=
><mo>=E2=88=88</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=AF</mi>=
</mrow></mrow><mo>]</mo><mo lspace=3D"0em">.</mo></mrow><annotation encodin=
g=3D"application/x-tex">g_{t\star t^{\prime}\leftarrow t^{\prime}}=3Df_{t}\=
quad\mathopen{}\mathclose{{\left[\textrm{for all }t,t^{\prime}\in\mathcal{T=
}}}\right].</annotation></semantics></math></td>
<td class=3D"ltx_eqn_cell ltx_eqn_center_padright"></td>
<td class=3D"ltx_eqn_cell ltx_eqn_eqno ltx_align_middle ltx_align_right" ro=
wspan=3D"1"><span class=3D"ltx_tag ltx_tag_equation ltx_align_right">(22)</=
span></td>
</tr></tbody>
</table>
<p class=3D"ltx_p" id=3D"S2.SS3.p1.6">It then follows immediately from the =
subsidiary divisibility condition
(<a class=3D"ltx_ref" href=3D"https://arxiv.org/html/2309.03085v2#S2.E19" t=
itle=3D"In 5th item =E2=80=A3 2.2 Markovian Dynamical Systems =E2=80=A3 2 D=
eterministic Systems =E2=80=A3 The Stochastic-Quantum Theorem"><span class=
=3D"ltx_text ltx_ref_tag">19</span></a>)
that the dynamical map <math alttext=3D"f:\mathcal{X}\times\mathcal{T}\to\m=
athcal{X}" class=3D"ltx_Math" display=3D"inline" id=3D"S2.SS3.p1.2.m1" inte=
nt=3D":literal"><semantics><mrow><mi>f</mi><mo lspace=3D"0.278em" rspace=3D=
"0.278em">:</mo><mrow><mrow><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=
=92=B3</mi><mo lspace=3D"0.222em" rspace=3D"0.222em">=C3=97</mo><mi class=
=3D"ltx_font_mathcaligraphic">=F0=9D=92=AF</mi></mrow><mo stretchy=3D"false=
">=E2=86=92</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=B3</mi></m=
row></mrow><annotation encoding=3D"application/x-tex">f:\mathcal{X}\times\m=
athcal{T}\to\mathcal{X}</annotation></semantics></math>
gives a semigroup action of the set of times <math alttext=3D"\mathcal{T}" =
class=3D"ltx_Math" display=3D"inline" id=3D"S2.SS3.p1.3.m2" intent=3D":lite=
ral"><semantics><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=AF</mi><an=
notation encoding=3D"application/x-tex">\mathcal{T}</annotation></semantics=
></math> on the
state space <math alttext=3D"\mathcal{X}" class=3D"ltx_Math" display=3D"inl=
ine" id=3D"S2.SS3.p1.4.m3" intent=3D":literal"><semantics><mi class=3D"ltx_=
font_mathcaligraphic">=F0=9D=92=B3</mi><annotation encoding=3D"application/=
x-tex">\mathcal{X}</annotation></semantics></math>, in the sense that the s=
emigroup operation
<math alttext=3D"\star" class=3D"ltx_Math" display=3D"inline" id=3D"S2.SS3.=
p1.5.m4" intent=3D":literal"><semantics><mo>=E2=8B=86</mo><annotation encod=
ing=3D"application/x-tex">\star</annotation></semantics></math> on <math al=
ttext=3D"\mathcal{T}" class=3D"ltx_Math" display=3D"inline" id=3D"S2.SS3.p1=
.6.m5" intent=3D":literal"><semantics><mi class=3D"ltx_font_mathcaligraphic=
">=F0=9D=92=AF</mi><annotation encoding=3D"application/x-tex">\mathcal{T}</=
annotation></semantics></math> is mapped to function composition:</p><butto=
n class=3D"sr-only button" style=3D"display: none;">Report issue for preced=
ing element</button>
<table class=3D"ltx_equation ltx_eqn_table" id=3D"S2.E23">
<tbody><tr class=3D"ltx_equation ltx_eqn_row ltx_align_baseline">
<td class=3D"ltx_eqn_cell ltx_eqn_center_padleft"></td>
<td class=3D"ltx_eqn_cell ltx_align_center"><math alttext=3D"f_{t\star t^{\=
prime}}=3Df_{t}\circ f_{t^{\prime}}\quad\mathopen{}\mathclose{{\left[\textr=
m{for all }t,t^{\prime}\in\mathcal{T}}}\right]." class=3D"ltx_math_unparsed=
" display=3D"block" id=3D"S2.E23.m1" intent=3D":literal"><semantics><mrow><=
msub><mi>f</mi><mrow><mi>t</mi><mo lspace=3D"0.222em" rspace=3D"0.222em">=
=E2=8B=86</mo><msup><mi>t</mi><mo>=E2=80=B2</mo></msup></mrow></msub><mo>=
=3D</mo><msub><mi>f</mi><mi>t</mi></msub><mo lspace=3D"0.222em" rspace=3D"0=
.222em">=E2=88=98</mo><msub><mi>f</mi><msup><mi>t</mi><mo>=E2=80=B2</mo></m=
sup></msub><mspace style=3D"width:1em;" width=3D"1em"></mspace><mrow><mi></=
mi><mrow><mo>[</mo><mtext>for all&nbsp;</mtext><mi>t</mi><mo>,</mo><msup><m=
i>t</mi><mo>=E2=80=B2</mo></msup><mo>=E2=88=88</mo><mi class=3D"ltx_font_ma=
thcaligraphic">=F0=9D=92=AF</mi></mrow></mrow><mo>]</mo><mo lspace=3D"0em">=
.</mo></mrow><annotation encoding=3D"application/x-tex">f_{t\star t^{\prime=
}}=3Df_{t}\circ f_{t^{\prime}}\quad\mathopen{}\mathclose{{\left[\textrm{for=
 all }t,t^{\prime}\in\mathcal{T}}}\right].</annotation></semantics></math><=
/td>
<td class=3D"ltx_eqn_cell ltx_eqn_center_padright"></td>
<td class=3D"ltx_eqn_cell ltx_eqn_eqno ltx_align_middle ltx_align_right" ro=
wspan=3D"1"><span class=3D"ltx_tag ltx_tag_equation ltx_align_right">(23)</=
span></td>
</tr></tbody>
</table>
<p class=3D"ltx_p" id=3D"S2.SS3.p1.8">This equation is an example of homoge=
neity in time, which implies
that time evolution depends only on duration and not on absolute times.</p>=
<button class=3D"sr-only button" style=3D"display: none;">Report issue for =
preceding element</button>
</div>
<div class=3D"ltx_para" id=3D"S2.SS3.p2">
<p class=3D"ltx_p" id=3D"S2.SS3.p2.5">Notice that the homogeneity property =
(<a class=3D"ltx_ref" href=3D"https://arxiv.org/html/2309.03085v2#S2.E23" t=
itle=3D"In 2.3 Markovian-Homogeneous Dynamical Systems =E2=80=A3 2 Determin=
istic Systems =E2=80=A3 The Stochastic-Quantum Theorem"><span class=3D"ltx_=
text ltx_ref_tag">23</span></a>)
is phrased directly in terms of a dynamical map <math alttext=3D"f" class=
=3D"ltx_Math" display=3D"inline" id=3D"S2.SS3.p2.1.m1" intent=3D":literal">=
<semantics><mi>f</mi><annotation encoding=3D"application/x-tex">f</annotati=
on></semantics></math>, so it can be
imposed on an indivisible dynamical system <math alttext=3D"\mathopen{}\mat=
hclose{{\left(\mathcal{X},\mathcal{T},f}}\right)" class=3D"ltx_math_unparse=
d" display=3D"inline" id=3D"S2.SS3.p2.2.m2" intent=3D":literal"><semantics>=
<mrow><mrow><mi></mi><mrow><mo>(</mo><mi class=3D"ltx_font_mathcaligraphic"=
>=F0=9D=92=B3</mi><mo>,</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=
=92=AF</mi><mo>,</mo><mi>f</mi></mrow></mrow><mo>)</mo></mrow><annotation e=
ncoding=3D"application/x-tex">\mathopen{}\mathclose{{\left(\mathcal{X},\mat=
hcal{T},f}}\right)</annotation></semantics></math>,
without any need to invoke a transition map <math alttext=3D"g" class=3D"lt=
x_Math" display=3D"inline" id=3D"S2.SS3.p2.3.m3" intent=3D":literal"><seman=
tics><mi>g</mi><annotation encoding=3D"application/x-tex">g</annotation></s=
emantics></math>. In that case, it
also follows that there is no longer a meaningful distinction between
an indivisible dynamical system <math alttext=3D"\mathopen{}\mathclose{{\le=
ft(\mathcal{X},\mathcal{T},f}}\right)" class=3D"ltx_math_unparsed" display=
=3D"inline" id=3D"S2.SS3.p2.4.m4" intent=3D":literal"><semantics><mrow><mro=
w><mi></mi><mrow><mo>(</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=
=B3</mi><mo>,</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=AF</mi><=
mo>,</mo><mi>f</mi></mrow></mrow><mo>)</mo></mrow><annotation encoding=3D"a=
pplication/x-tex">\mathopen{}\mathclose{{\left(\mathcal{X},\mathcal{T},f}}\=
right)</annotation></semantics></math>
and a Markovian dynamical system <math alttext=3D"\mathopen{}\mathclose{{\l=
eft(\mathcal{X},\mathcal{T},g}}\right)" class=3D"ltx_math_unparsed" display=
=3D"inline" id=3D"S2.SS3.p2.5.m5" intent=3D":literal"><semantics><mrow><mro=
w><mi></mi><mrow><mo>(</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=
=B3</mi><mo>,</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=AF</mi><=
mo>,</mo><mi>g</mi></mrow></mrow><mo>)</mo></mrow><annotation encoding=3D"a=
pplication/x-tex">\mathopen{}\mathclose{{\left(\mathcal{X},\mathcal{T},g}}\=
right)</annotation></semantics></math>.
As such, if the homogeneity property (<a class=3D"ltx_ref" href=3D"https://=
arxiv.org/html/2309.03085v2#S2.E23" title=3D"In 2.3 Markovian-Homogeneous D=
ynamical Systems =E2=80=A3 2 Deterministic Systems =E2=80=A3 The Stochastic=
-Quantum Theorem"><span class=3D"ltx_text ltx_ref_tag">23</span></a>)
is imposed, then the resulting mathematical structure will simply
be called a Markovian-homogeneous dynamical system.</p><button class=3D"sr-=
only button" style=3D"display: none;">Report issue for preceding element</b=
utton>
</div>
<div class=3D"ltx_para" id=3D"S2.SS3.p3">
<p class=3D"ltx_p" id=3D"S2.SS3.p3.4">What most references call a dynamical=
 system corresponds to what this
paper would call a Markovian-homogeneous dynamical system. That is,
a dynamical system, without any further qualifiers, is a tuple <math alttex=
t=3D"\mathopen{}\mathclose{{\left(\mathcal{X},\mathcal{T},f}}\right)" class=
=3D"ltx_math_unparsed" display=3D"inline" id=3D"S2.SS3.p3.1.m1" intent=3D":=
literal"><semantics><mrow><mrow><mi></mi><mrow><mo>(</mo><mi class=3D"ltx_f=
ont_mathcaligraphic">=F0=9D=92=B3</mi><mo>,</mo><mi class=3D"ltx_font_mathc=
aligraphic">=F0=9D=92=AF</mi><mo>,</mo><mi>f</mi></mrow></mrow><mo>)</mo></=
mrow><annotation encoding=3D"application/x-tex">\mathopen{}\mathclose{{\lef=
t(\mathcal{X},\mathcal{T},f}}\right)</annotation></semantics></math>
for which <math alttext=3D"\mathcal{X}" class=3D"ltx_Math" display=3D"inlin=
e" id=3D"S2.SS3.p3.2.m2" intent=3D":literal"><semantics><mi class=3D"ltx_fo=
nt_mathcaligraphic">=F0=9D=92=B3</mi><annotation encoding=3D"application/x-=
tex">\mathcal{X}</annotation></semantics></math> is a state space, <math al=
ttext=3D"\mathcal{T}" class=3D"ltx_Math" display=3D"inline" id=3D"S2.SS3.p3=
.3.m3" intent=3D":literal"><semantics><mi class=3D"ltx_font_mathcaligraphic=
">=F0=9D=92=AF</mi><annotation encoding=3D"application/x-tex">\mathcal{T}</=
annotation></semantics></math> is a set
of times forming a monoid, and <math alttext=3D"f:\mathcal{X}\times\mathcal=
{T}\to\mathcal{X}" class=3D"ltx_Math" display=3D"inline" id=3D"S2.SS3.p3.4.=
m4" intent=3D":literal"><semantics><mrow><mi>f</mi><mo lspace=3D"0.278em" r=
space=3D"0.278em">:</mo><mrow><mrow><mi class=3D"ltx_font_mathcaligraphic">=
=F0=9D=92=B3</mi><mo lspace=3D"0.222em" rspace=3D"0.222em">=C3=97</mo><mi c=
lass=3D"ltx_font_mathcaligraphic">=F0=9D=92=AF</mi></mrow><mo stretchy=3D"f=
alse">=E2=86=92</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=B3</mi=
></mrow></mrow><annotation encoding=3D"application/x-tex">f:\mathcal{X}\tim=
es\mathcal{T}\to\mathcal{X}</annotation></semantics></math>
is a dynamical map satisfying the homogeneity property (<a class=3D"ltx_ref=
" href=3D"https://arxiv.org/html/2309.03085v2#S2.E23" title=3D"In 2.3 Marko=
vian-Homogeneous Dynamical Systems =E2=80=A3 2 Deterministic Systems =E2=80=
=A3 The Stochastic-Quantum Theorem"><span class=3D"ltx_text ltx_ref_tag">23=
</span></a>).
It follows that an indivisible dynamical system (<a class=3D"ltx_ref" href=
=3D"https://arxiv.org/html/2309.03085v2#S2.E1" title=3D"In 2.1 Indivisible =
Dynamical Systems =E2=80=A3 2 Deterministic Systems =E2=80=A3 The Stochasti=
c-Quantum Theorem"><span class=3D"ltx_text ltx_ref_tag">1</span></a>)
is a generalization of the kinds of dynamical systems that are usually
considered in textbooks, in the research literature, and in many applicatio=
ns.</p><button class=3D"sr-only button" style=3D"display: none;">Report iss=
ue for preceding element</button>
</div>
<div class=3D"ltx_para" id=3D"S2.SS3.p4">
<p class=3D"ltx_p" id=3D"S2.SS3.p4.8">In the most general cases, however, i=
ndivisible dynamical systems
will not satisfy the homogeneity property (<a class=3D"ltx_ref" href=3D"htt=
ps://arxiv.org/html/2309.03085v2#S2.E23" title=3D"In 2.3 Markovian-Homogene=
ous Dynamical Systems =E2=80=A3 2 Deterministic Systems =E2=80=A3 The Stoch=
astic-Quantum Theorem"><span class=3D"ltx_text ltx_ref_tag">23</span></a>).
Nor will it necessarily be possible to obtain a given indivisible
dynamical system <math alttext=3D"\mathopen{}\mathclose{{\left(\mathcal{X},=
\mathcal{T},f}}\right)" class=3D"ltx_math_unparsed" display=3D"inline" id=
=3D"S2.SS3.p4.1.m1" intent=3D":literal"><semantics><mrow><mrow><mi></mi><mr=
ow><mo>(</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=B3</mi><mo>,<=
/mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=AF</mi><mo>,</mo><mi>f=
</mi></mrow></mrow><mo>)</mo></mrow><annotation encoding=3D"application/x-t=
ex">\mathopen{}\mathclose{{\left(\mathcal{X},\mathcal{T},f}}\right)</annota=
tion></semantics></math> by starting
with a Markovian dynamical system <math alttext=3D"\mathopen{}\mathclose{{\=
left(\mathcal{X},\mathcal{T},g}}\right)" class=3D"ltx_math_unparsed" displa=
y=3D"inline" id=3D"S2.SS3.p4.2.m2" intent=3D":literal"><semantics><mrow><mr=
ow><mi></mi><mrow><mo>(</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=
=92=B3</mi><mo>,</mo><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=AF</m=
i><mo>,</mo><mi>g</mi></mrow></mrow><mo>)</mo></mrow><annotation encoding=
=3D"application/x-tex">\mathopen{}\mathclose{{\left(\mathcal{X},\mathcal{T}=
,g}}\right)</annotation></semantics></math>
and then defining a dynamical map <math alttext=3D"f" class=3D"ltx_Math" di=
splay=3D"inline" id=3D"S2.SS3.p4.3.m3" intent=3D":literal"><semantics><mi>f=
</mi><annotation encoding=3D"application/x-tex">f</annotation></semantics><=
/math> according to <math alttext=3D"f_{t}\equiv g_{t\leftarrow 0}" class=
=3D"ltx_Math" display=3D"inline" id=3D"S2.SS3.p4.4.m4" intent=3D":literal">=
<semantics><mrow><msub><mi>f</mi><mi>t</mi></msub><mo>=E2=89=A1</mo><msub><=
mi>g</mi><mrow><mi>t</mi><mo stretchy=3D"false">=E2=86=90</mo><mn>0</mn></m=
row></msub></mrow><annotation encoding=3D"application/x-tex">f_{t}\equiv g_=
{t\leftarrow 0}</annotation></semantics></math>
for all times <math alttext=3D"t" class=3D"ltx_Math" display=3D"inline" id=
