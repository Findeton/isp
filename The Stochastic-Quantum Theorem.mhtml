<ul class=3D"ltx_itemize" id=3D"S2.I2">
<li class=3D"ltx_item" id=3D"S2.I2.i1" style=3D"list-style-type:none;">
<span class=3D"ltx_tag ltx_tag_item">=E2=80=A2</span>
<div class=3D"ltx_para" id=3D"S2.I2.i1.p1">
<p class=3D"ltx_p" id=3D"S2.I2.i1.p1.3">Here <math alttext=3D"\mathcal{X}" =
class=3D"ltx_Math" display=3D"inline" id=3D"S2.I2.i1.p1.1.m1" intent=3D":li=
teral"><semantics><mi class=3D"ltx_font_mathcaligraphic">=F0=9D=92=B3</mi><=
